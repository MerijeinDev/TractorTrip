<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/locked_outer" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/locked_inner_dark"
                android:startColor="@color/locked_inner_light"
                android:type="linear" />
            <corners android:radius="15dp" />
        </shape>
    </item>

</layer-list>
