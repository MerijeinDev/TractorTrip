<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/menu_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_top_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.05" />

        <FrameLayout
            android:id="@+id/btn_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="20dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/gl_top_safe">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/cd_back"
                android:scaleType="fitXY"
                android:src="@drawable/btn_settings_plate" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_arrow_back" />

        </FrameLayout>

        <farmyard.tractortrip.lab.OutlinedTextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/erica_one"
            android:includeFontPadding="false"
            android:letterSpacing="0.04"
            android:text="@string/settings_title"
            android:textAllCaps="true"
            android:textColor="@color/text_white"
            android:textSize="30sp"
            app:layout_constraintBottom_toTopOf="@id/panel_toggles"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintVertical_chainStyle="packed"
            app:outlineStrokeColorBottom="#722501"
            app:outlineStrokeColorTop="#D95500"
            app:outlineStrokeWidth="6dp" />

        <LinearLayout
            android:id="@+id/panel_toggles"
            android:layout_width="380dp"
            android:layout_height="220dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="177dp"
            android:background="@drawable/shop_card_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="22dp"
            android:paddingVertical="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_settings_title">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <farmyard.tractortrip.lab.OutlinedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/erica_one"
                    android:text="@string/settings_music"
                    android:textAllCaps="true"
                    android:textColor="@color/text_white"
                    android:textSize="20sp"
                    app:outlineStrokeColorBottom="#722501"
                    app:outlineStrokeColorTop="#D95500"
                    app:outlineStrokeWidth="3dp" />

                <FrameLayout
                    android:id="@+id/btn_music"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iv_music_plate"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitXY"
                        android:src="@drawable/btn_settings_plate" />

                    <ImageView
                        android:id="@+id/iv_music_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_music" />

                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <farmyard.tractortrip.lab.OutlinedTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/erica_one"
                    android:text="@string/settings_sound"
                    android:textAllCaps="true"
                    android:textColor="@color/text_white"
                    android:textSize="20sp"
                    app:outlineStrokeColorBottom="#722501"
                    app:outlineStrokeColorTop="#D95500"
                    app:outlineStrokeWidth="3dp" />

                <FrameLayout
                    android:id="@+id/btn_sound"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iv_sound_plate"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@null"
                        android:scaleType="fitXY"
                        android:src="@drawable/btn_settings_plate" />

                    <ImageView
                        android:id="@+id/iv_sound_icon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_sound" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
