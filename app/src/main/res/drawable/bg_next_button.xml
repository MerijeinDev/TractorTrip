<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/caution_black" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/caution_yellow" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp"
        android:top="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="@color/next_button_bottom"
                android:startColor="@color/next_button_top"
                android:type="linear" />
            <corners android:radius="14dp" />
        </shape>
    </item>

</layer-list>
