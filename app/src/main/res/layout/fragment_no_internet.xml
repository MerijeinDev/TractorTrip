<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/no_internet_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/popup_dim"
    android:clickable="true"
    android:focusable="true"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="32dp"
        android:background="@drawable/bg_popup_card"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="22dp">

        <TextView
            android:id="@+id/tv_no_internet_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:shadowColor="@color/text_outline_brown"
            android:shadowDx="0"
            android:shadowDy="3"
            android:shadowRadius="6"
            android:text="@string/no_internet_title"
            android:textAllCaps="true"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_no_internet_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/no_internet_message"
            android:textColor="@color/wood_brown_dark"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_no_internet_title" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="@dimen/next_button_width"
            android:layout_height="@dimen/next_button_height"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_next_button"
            android:fontFamily="sans-serif-black"
            android:minHeight="0dp"
            android:stateListAnimator="@null"
            android:text="@string/no_internet_retry"
            android:textAllCaps="true"
            android:textColor="@color/text_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_no_internet_message" />

        <Button
            android:id="@+id/btn_offline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@android:color/transparent"
            android:fontFamily="sans-serif-black"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp"
            android:stateListAnimator="@null"
            android:text="@string/no_internet_offline"
            android:textAllCaps="true"
            android:textColor="@color/wood_brown_dark"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_retry" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
