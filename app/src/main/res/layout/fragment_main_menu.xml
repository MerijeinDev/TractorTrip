<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/menu_bg" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_top_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.05" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_start_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.05" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_end_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.95" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gl_bottom_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.96" />

        <LinearLayout
            android:id="@+id/panel_coins"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:background="@drawable/coin_panel_bg"
            android:gravity="center_vertical"
            android:minWidth="110dp"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            app:layout_constraintStart_toStartOf="@id/gl_start_safe"
            app:layout_constraintTop_toTopOf="@id/gl_top_safe">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@string/cd_coins"
                android:src="@drawable/ic_coin" />

            <farmyard.tractortrip.lab.OutlinedTextView
                android:id="@+id/tv_coin_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/erica_one"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                app:outlineStrokeColorBottom="#722501"
                app:outlineStrokeColorTop="#D95500"
                app:outlineStrokeWidth="3dp"
                tools:text="1250" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/btn_settings_shortcut"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="@id/gl_end_safe"
            app:layout_constraintTop_toTopOf="@id/gl_top_safe">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/menu_settings"
                android:scaleType="fitXY"
                android:src="@drawable/btn_settings_plate" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_settings" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_play"
            android:layout_width="273dp"
            android:layout_height="129dp"
            android:layout_marginBottom="18dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toTopOf="@id/btn_shop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/menu_play"
                android:scaleType="fitXY"
                android:src="@drawable/btn_play_plate" />

            <farmyard.tractortrip.lab.OutlinedTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/erica_one"
                android:includeFontPadding="false"
                android:letterSpacing="0.04"
                android:text="@string/menu_play"
                android:textAllCaps="true"
                android:textColor="@color/text_white"
                android:textSize="44sp"
                app:outlineStrokeColorBottom="#722501"
                app:outlineStrokeColorTop="#D95500"
                app:outlineStrokeWidth="6dp" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_shop"
            android:layout_width="161dp"
            android:layout_height="111dp"
            android:background="@drawable/btn_secondary_plate"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/gl_bottom_safe"
            app:layout_constraintEnd_toStartOf="@id/btn_achievements"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_cart" />

                    <farmyard.tractortrip.lab.OutlinedTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/erica_one"
                        android:text="@string/menu_shop"
                        android:textAllCaps="true"
                        android:textColor="@color/text_white"
                        android:textSize="20sp"
                        app:outlineStrokeColorBottom="#722501"
                        app:outlineStrokeColorTop="#D95500"
                        app:outlineStrokeWidth="3dp" />

                </FrameLayout>


            </LinearLayout>

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_achievements"
            android:layout_width="161dp"
            android:layout_height="111dp"
            android:background="@drawable/btn_secondary_plate"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/gl_bottom_safe"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_shop">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_medal" />

                    <farmyard.tractortrip.lab.OutlinedTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/erica_one"
                        android:text="@string/menu_badges"
                        android:textAllCaps="true"
                        android:textColor="@color/text_white"
                        android:textSize="18sp"
                        app:outlineStrokeColorBottom="#722501"
                        app:outlineStrokeColorTop="#D95500"
                        app:outlineStrokeWidth="3dp" />


                </FrameLayout>


            </LinearLayout>

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>