<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tile_root"
    android:layout_width="match_parent"
    android:layout_height="@dimen/level_tile_height"
    android:layout_margin="@dimen/level_tile_spacing"
    android:background="@drawable/bg_level_tile_unlocked"
    android:padding="0dp">

    <TextView
        android:id="@+id/tv_level_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:includeFontPadding="false"
        android:shadowColor="@color/text_outline_brown"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:textColor="@color/text_white"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@id/row_stars"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="12" />

    <LinearLayout
        android:id="@+id/row_stars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_level_number"
        app:layout_constraintVertical_bias="0.42"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/iv_star_1"
            android:layout_width="@dimen/level_star_size"
            android:layout_height="@dimen/level_star_size"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_star_empty" />

        <ImageView
            android:id="@+id/iv_star_2"
            android:layout_width="@dimen/level_star_size"
            android:layout_height="@dimen/level_star_size"
            android:layout_marginHorizontal="1dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_star_empty" />

        <ImageView
            android:id="@+id/iv_star_3"
            android:layout_width="@dimen/level_star_size"
            android:layout_height="@dimen/level_star_size"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_star_empty" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
