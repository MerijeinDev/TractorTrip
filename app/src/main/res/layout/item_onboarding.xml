<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:src="@drawable/onboarding_bg_placeholder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_start_safe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_end_safe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_bottom_safe"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.90" />

    <TextView
        android:id="@+id/tv_onboarding_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/onboarding_text_button_gap"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:shadowColor="@color/text_outline_brown"
        android:shadowDx="0"
        android:shadowDy="3"
        android:shadowRadius="6"
        android:textColor="@color/text_white"
        android:textSize="@dimen/onboarding_text_size"
        app:layout_constraintBottom_toTopOf="@id/btn_next"
        app:layout_constraintEnd_toEndOf="@id/gl_end_safe"
        app:layout_constraintStart_toStartOf="@id/gl_start_safe"
        tools:text="Watch your fuel. Pick up gas cans to refuel before the engine stops." />

    <FrameLayout
        android:id="@+id/btn_next"
        android:layout_width="@dimen/onboarding_button_width"
        android:layout_height="@dimen/onboarding_button_height"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="@id/gl_bottom_safe"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/iv_btn_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/onboarding_next"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/btn_onboarding" />

        <TextView
            android:id="@+id/tv_btn_label"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:includeFontPadding="false"
            android:letterSpacing="0.08"
            android:shadowColor="@color/text_outline_brown"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:textAllCaps="true"
            android:textColor="@color/text_white"
            android:textSize="@dimen/onboarding_button_text_size"
            android:visibility="gone"
            tools:text="PLAY"
            tools:visibility="visible" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
