<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/achievement_card_spacing">

    <ImageView
        android:id="@+id/iv_card_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/shop_card_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="380:220"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_medal"
        android:layout_width="80dp"
        android:layout_height="60dp"
        android:layout_marginTop="22dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_medal"
        app:layout_constraintEnd_toEndOf="@id/iv_card_bg"
        app:layout_constraintStart_toStartOf="@id/iv_card_bg"
        app:layout_constraintTop_toTopOf="@id/iv_card_bg" />

    <com.tractorfieldtrip.OutlinedTextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/erica_one"
        android:gravity="center"
        android:includeFontPadding="false"
        android:letterSpacing="0.02"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAllCaps="false"
        android:textColor="@color/text_white"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="@id/iv_card_bg"
        app:layout_constraintStart_toStartOf="@id/iv_card_bg"
        app:layout_constraintTop_toBottomOf="@id/iv_medal"
        app:outlineStrokeColorBottom="#722501"
        app:outlineStrokeColorTop="#D95500"
        app:outlineStrokeWidth="3dp"
        tools:text="First Trip" />

    <TextView
        android:id="@+id/tv_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="28dp"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/erica_one"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/text_white"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="@id/iv_card_bg"
        app:layout_constraintStart_toStartOf="@id/iv_card_bg"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        tools:text="Collect your first material" />

</androidx.constraintlayout.widget.ConstraintLayout>
